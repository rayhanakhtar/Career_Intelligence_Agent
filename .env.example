# =============================================================================
# Career Intelligence Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your local setup.
#   cp .env.example .env
# =============================================================================

# --- Database ----------------------------------------------------------------
# Path to the SQLite database file.
# DATABASE_PATH=jobs.db

# --- CORS --------------------------------------------------------------------
# Comma-separated list of allowed origins for CORS.
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Company Registry --------------------------------------------------------
# Path to the company registry file (YAML or JSON).
# COMPANIES_PATH=data/companies.yml

# --- Logging -----------------------------------------------------------------
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# --- Scheduler (APScheduler) -------------------------------------------------
# Enable or disable the scheduled crawl job.
# SCHEDULER_ENABLED=true
# Interval between scheduled crawls in hours.
# SCHEDULER_INTERVAL_HOURS=6

# --- FAISS Index -------------------------------------------------------------
# Directory where the persistent FAISS index is stored.
# FAISS_INDEX_DIR=faiss_index
